{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/json_schema/capability.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text"
  ]
}
